# ============================================================
# FLASK CONFIGURATION
# ============================================================
FLASK_ENV=development
SECRET_KEY=dev-secret-key-change-in-production
JWT_SECRET_KEY=jwt-secret-key-change-in-production

# ============================================================
# DATABASE CONFIGURATION
# ============================================================
# Local MongoDB:
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=disease_prediction
# MongoDB Atlas example:
# MONGODB_URI=mongodb+srv://username:password@cluster0.mongodb.net/?retryWrites=true&w=majority
# MONGODB_DB=disease_prediction

# ============================================================
# MODEL LOADING / RETRAIN
# ============================================================
# Set to true for one deployment to force rebuild of model artifacts
# in the same runtime environment (helps resolve sklearn pickle mismatch).
FORCE_RETRAIN_MODEL_ON_STARTUP=false

# ============================================================
# EMAIL CONFIGURATION (REQUIRED FOR OTP)
# ============================================================
# Gmail Setup Instructions:
# 1. Enable 2FA in Google Account
# 2. Go to https://myaccount.google.com/apppasswords
# 3. Select "Mail" and "Windows Computer"
# 4. Generate and copy the 16-character password
# 5. Paste below as MAIL_PASSWORD (NOT your regular Gmail password!)

MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-specific-password
MAIL_DEFAULT_SENDER=noreply@healthguard.com

# Alternative Email Providers:
# Outlook:
#   MAIL_SERVER=smtp-mail.outlook.com
#   MAIL_PORT=587
# Yahoo:
#   MAIL_SERVER=smtp.mail.yahoo.com
#   MAIL_PORT=587
# Custom SMTP:
#   MAIL_SERVER=your-smtp-server.com
#   MAIL_PORT=587 or 465
#   MAIL_USE_TLS=True or False

# ============================================================
# OTP CONFIGURATION
# ============================================================
OTP_VALIDITY_MINUTES=5
OTP_MAX_ATTEMPTS=3

# ============================================================
# LLM REVIEW LAYER (Optional - OpenRouter)
# ============================================================
# When enabled, ML predictions are sanity-checked before being returned.
ENABLE_LLM_REVIEW=true
# If true, every prediction must use LLM review output (fails when LLM is unavailable).
LLM_FORCE_ALL_CASES=false
# If ML confidence is below this value, LLM-selected result is forced (when LLM is available).
LLM_FORCE_BELOW_CONFIDENCE=50
# If top model support is below this value, LLM may select beyond top-3 from known diseases.
LLM_WEAK_SUPPORT_THRESHOLD=50
OPENROUTER_API_KEY=
OPENROUTER_API_KEY_FALLBACK=
OPENROUTER_API_KEY_TERTIARY=
OPENROUTER_MODEL=qwen/qwen3-next-80b-a3b-instruct:free
OPENROUTER_MODEL_FALLBACK=openai/gpt-oss-120b:free
OPENROUTER_MODEL_TERTIARY=qwen/qwen3.6-plus:free
OPENROUTER_API_URL=https://openrouter.ai/api/v1/chat/completions
OPENROUTER_TIMEOUT_SECONDS=20
OPENROUTER_RATE_LIMIT_COOLDOWN_SECONDS=120
OPENROUTER_BILLING_COOLDOWN_SECONDS=900
# Optional headers recommended by OpenRouter
OPENROUTER_SITE_URL=http://localhost:5000
OPENROUTER_SITE_NAME=HealthGuard

# ============================================================
# ABHA API CONFIGURATION (Optional - For Government Health Account)
# ============================================================
# Register at:
#   Development: https://healthiddev.ndhm.gov.in
#   Production: https://healthid.ndhm.gov.in
# Get credentials from NDHM Developer Portal

ABHA_API_URL=https://healthiddev.ndhm.gov.in
ABHA_CLIENT_ID=your-abha-client-id
ABHA_CLIENT_SECRET=your-abha-client-secret
ABHA_REDIRECT_URI=http://localhost:5000/api/abha/callback

# ============================================================
# CORS CONFIGURATION
# ============================================================
# For development: * (allow all origins)
# For production: https://yourdomain.com,https://www.yourdomain.com
CORS_ORIGINS=*

# ============================================================
# SECURITY & LOGGING
# ============================================================
DEBUG=True
LOG_LEVEL=INFO
LOG_FILE=app.log

# JWT Token Expiry (in seconds)
JWT_ACCESS_TOKEN_EXPIRES=2592000
JWT_REFRESH_TOKEN_EXPIRES=7776000
