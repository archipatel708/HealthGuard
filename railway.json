{
  "$schema": "https://railway.app/railway.schema.json",
  "deploy": {
    "startCommand": "sh -c 'gunicorn --workers ${WEB_CONCURRENCY:-1} --threads ${GUNICORN_THREADS:-4} --timeout ${GUNICORN_TIMEOUT:-120} --bind 0.0.0.0:${PORT:-8080} app:app'",
    "healthcheckPath": "/",
    "healthcheckTimeout": 180
  }
}
